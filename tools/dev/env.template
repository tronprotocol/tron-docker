# TRON Private Chain Development Environment Configuration Template
# Copy this file to .env for use
# cp env.template .env

# ============================================
# Java-Tron Source Configuration
# ============================================
# Git repository URL (optional, uses default if not set)
# Default: https://github.com/tronprotocol/java-tron.git
#REPO=https://github.com/tronprotocol/java-tron.git

# Branch name (optional, uses default if not set)
# Default: master
#BRANCH=master

# Example using your own fork:
# REPO=https://github.com/your-name/java-tron.git
# BRANCH=develop

# ============================================
# Port Configuration
# ============================================
# SR node ports (optional, not exposed by default)
# If you need to access SR from host, uncomment and enable in docker-compose
#SR_HTTP_PORT=8090
#SR_SOLIDITY_PORT=8091
#SR_GRPC_PORT=50051
#SR_P2P_PORT=18888

# Fullnode ports (exposed by default, using java-tron default ports)
#FULLNODE_HTTP_PORT=8090
#FULLNODE_SOLIDITY_PORT=8091
#FULLNODE_GRPC_PORT=50051
#FULLNODE_METRICS_PORT=9527

# ============================================
# Resource Configuration
# ============================================
# SR node memory limit
SR_MEMORY=8g

# Fullnode memory limit
FULLNODE_MEMORY=8g
