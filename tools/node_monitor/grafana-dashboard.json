{
  "id": null,
  "uid": "sr-empty-block-monitor",
  "title": "SR Empty Block & SR Set Monitor",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["tron", "sr-monitor"],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "refresh": 1,
        "hide": 0,
        "label": "Node",
        "query": {
          "query": "label_values(tron_last_block_number, node)",
          "refId": "StandardVariableQuery"
        },
        "includeAll": false,
        "multi": false,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Last Block Number",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "max(tron_last_block_number{node=~\"$node\"})",
          "legendFormat": "last block",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": false
        },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "type": "stat",
      "title": "Last Block Timestamp (s)",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "max(tron_last_block_timestamp{node=~\"$node\"})",
          "legendFormat": "last ts",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": false
        },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "type": "stat",
      "title": "Empty Blocks (Last 24h)",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(increase(tron_empty_blocks_total{node=~\"$node\"}[24h]))",
          "legendFormat": "empty blocks",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": false
        },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "type": "stat",
      "title": "Latest Block is Empty?",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "max(tron_empty_block_detected{node=~\"$node\"})",
          "legendFormat": "1 = empty, 0 = non-empty",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": false
        },
        "orientation": "horizontal",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Empty Block Ratio (Last 5m)",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (node) (increase(tron_empty_blocks_total{node=~\"$node\"}[5m])) / (sum by (node) (max_over_time(tron_last_block_number{node=~\"$node\"}[5m]) - min_over_time(tron_last_block_number{node=~\"$node\"}[5m])) + 1) * 100",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "SR Count",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "tron_sr_count{node=~\"$node\"}",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "SR Set Changes (added/removed/reordered)",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rate(tron_sr_set_changes_total{node=~\"$node\", change_type=\"added\"}[10m])",
          "legendFormat": "added",
          "refId": "A"
        },
        {
          "expr": "rate(tron_sr_set_changes_total{node=~\"$node\", change_type=\"removed\"}[10m])",
          "legendFormat": "removed",
          "refId": "B"
        },
        {
          "expr": "rate(tron_sr_set_changes_total{node=~\"$node\", change_type=\"reordered\"}[10m])",
          "legendFormat": "reordered",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Errors",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rate(tron_monitor_api_errors_total{node=~\"$node\"}[5m])",
          "legendFormat": "{{api_endpoint}} {{error_type}}",
          "refId": "A"
        }
      ]
    }
  ]
}
